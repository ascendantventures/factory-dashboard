# Factory Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# All values marked [REQUIRED] must be set for the app to function.

# ─── Supabase (Dashboard) ─────────────────────────────────────────────────────
# [REQUIRED] Your Supabase project URL
# Find it at: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anon key — safe to expose to the client
# Find it at: Supabase Dashboard → Project Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# [REQUIRED] Supabase service role key — server-side only, never expose to client
# Find it at: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub ───────────────────────────────────────────────────────────────────
# [REQUIRED] GitHub Personal Access Token for issue sync + creation
# Create at: GitHub → Settings → Developer settings → Personal access tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=ghp_your-token-here

# ─── Vercel (optional — enables deploy tracking) ──────────────────────────────
# Vercel personal/team access token (server-only, never exposed to client)
# Create at: Vercel → Account Settings → Tokens
# Without this, deployment fields show "—" on pipeline cards.
VERCEL_API_TOKEN=

# ─── Security ─────────────────────────────────────────────────────────────────
# [REQUIRED] 32-character AES-GCM key for encrypting webhook signing secrets
# Generate with: openssl rand -base64 32 | head -c 32
WEBHOOK_SECRET_ENCRYPTION_KEY=your-32-char-key-here

# ─── App URL (optional) ───────────────────────────────────────────────────────
# Set this in Vercel production to enable correct login redirects
NEXT_PUBLIC_APP_URL=https://factory-dashboard-tau.vercel.app

# ─── Harness .env (agenic-harness-beta) ──────────────────────────────────────
# These vars are required in the HARNESS .env file, NOT this dashboard .env.
# File location: /root/.openclaw/workspace/agentic-harness-beta/.env
#
# Without these, writeHarnessHeartbeat() silently no-ops and the pipeline
# page will permanently show "Stopped" / "Never connected".
#
# [REQUIRED for heartbeat] Supabase project URL (same value as NEXT_PUBLIC_SUPABASE_URL above)
# SUPABASE_URL=https://your-project.supabase.co
#
# [REQUIRED for heartbeat] Supabase service role key (same value as SUPABASE_SERVICE_ROLE_KEY above)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Retrieve both values from: Supabase Dashboard → Project Settings → API
